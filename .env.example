# -- Finnhub - stock/ETF quotes, fundamentals, earnings calendar ---------------
# Free signup: https://finnhub.io/register  (60 calls/min, no daily cap on free tier)
FINNHUB_API_KEY=

# -- FRED - macro series (Fed funds rate, CPI, unemployment, 10Y yield) --------
# Free signup: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# -- MarketAux - targeted news/sentiment for deep-dive candidates only ---------
# Free signup (no card required): https://www.marketaux.com/account/dashboard
MARKETAUX_API_KEY=

# -- SEC EDGAR - company facts (XBRL fundamentals), deep-dive stocks only ------
# No key/signup needed, but SEC requires a descriptive User-Agent on every
# request, format: "<app name> <your email>". Requests without one are
# rejected; see https://www.sec.gov/os/accessing-edgar-data
SEC_EDGAR_USER_AGENT=

# -- CoinGecko - crypto market data ---------------------------------------------
# No key needed for the free public API. Leave blank unless CoinGecko later
# requires a Demo key for your usage level: https://www.coingecko.com/en/api
COINGECKO_API_KEY=

# -- Optional --------------------------------------------------------------
LOG_LEVEL=INFO
